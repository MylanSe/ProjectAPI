# Configuration pour utilisation avec Docker Compose
# Copiez ce fichier vers .env pour l'utiliser

# Configuration de l'application
PORT=3000
NODE_ENV=production

# Configuration MongoDB (Docker)
MONGODB_URI=mongodb://admin:admin123@mongodb:27017/configurateur_pc?authSource=admin

# Configuration JWT
JWT_SECRET=votre_secret_jwt_super_securise_a_changer
JWT_EXPIRE=7d

# Compte administrateur par défaut
ADMIN_EMAIL=admin@configurateurpc.com
ADMIN_PASSWORD=Admin123!
